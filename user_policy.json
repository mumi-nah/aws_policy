{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowUserManagement",
      "Effect": "Allow",
      "Action": [
        "iam:CreateUser",
        "iam:GetUser",
        "iam:ListUsers",
        "iam:CreateLoginProfile",
        "iam:UpdateLoginProfile",
        "iam:ListUserPolicies",
        "iam:ListAttachedUserPolicies"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyDestructiveActions",
      "Effect": "Deny",
      "Action": [
        "iam:DeleteUser",
        "iam:DeletePolicy",
        "iam:CreateAccessKey"
      ],
      "Resource": "*"
    }
  ]
}
